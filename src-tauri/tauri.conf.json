{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "easyapply",
  "version": "2.1.1",
  "identifier": "com.xingwang.easyapply",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "easyapply",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./nsis/hooks.nsh"
      }
    }
  }
}
